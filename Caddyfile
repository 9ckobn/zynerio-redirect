# Caddyfile for the redirect (1-click connect) service.
#
# Runs inside a Docker container. Listens on :8080.
# Reverse-proxy to this from your main Caddy / nginx.
#
# Example (main Caddy on the host):
#   handle /add_sub* {
#       reverse_proxy localhost:8070
#   }

:8080 {
	root * /srv
	encode gzip

	# /add_sub?sub=...&app=... → serve the SPA
	handle /add_sub* {
		try_files {path} /index.html
		file_server
	}

	# Health check
	handle /health {
		respond "ok" 200
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
